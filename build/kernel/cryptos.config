# CryptOS hardened kernel config fragment.
#
# Merged onto the tiny base config (`make tinyconfig`, via
# scripts/kconfig/merge_config.sh) by build/kernel/build.sh. These are the
# options CryptOS depends on or hardens, plus the dependency substrate the tiny
# base omits. Keep this list reviewed — it is the kernel's security posture.
# build.sh fails the build if any `=y` here is dropped from the final .config.
#
# DRAFT: option set is the intended Phase 1 posture; validate it builds +
# boots in QEMU before relying on it. Bare-metal driver selection (NIC,
# NVMe, etc.) is layered on separately (see cryptos#33 / hardware notes).

# Dependency substrate. The base is `make tinyconfig` (allnoconfig + tiny),
# which leaves the prerequisites of the options below unset; without these,
# `olddefconfig` silently drops requested options that depend on symbols that
# are off. Enabling the substrate keeps the fragment minimal while letting the
# hardening/functional options actually take effect. build.sh asserts every
# requested `=y` survives the merge, so a future dep gap fails the build.
CONFIG_MULTIUSER=y
CONFIG_SYSFS=y
CONFIG_SHMEM=y
CONFIG_BLOCK=y
CONFIG_BLK_DEV=y
CONFIG_MD=y
CONFIG_PCI=y
CONFIG_ACPI=y
CONFIG_RELOCATABLE=y
CONFIG_KEYS=y
CONFIG_CRYPTO=y
CONFIG_HW_RANDOM=y
CONFIG_XZ_DEC=y
CONFIG_MISC_FILESYSTEMS=y
CONFIG_ASYMMETRIC_KEY_TYPE=y
CONFIG_ASYMMETRIC_PUBLIC_KEY_SUBTYPE=y
CONFIG_X509_CERTIFICATE_PARSER=y

# No loadable modules — every driver built in-tree (removes a loadable-code
# attack class).
CONFIG_MODULES=n

# Kernel lockdown in confidentiality mode, enforced from boot.
CONFIG_SECURITY=y
CONFIG_SECURITY_LOCKDOWN_LSM=y
CONFIG_SECURITY_LOCKDOWN_LSM_EARLY=y
CONFIG_LOCK_DOWN_KERNEL_FORCE_CONFIDENTIALITY=y

# Secure Boot / UEFI + signature checking.
CONFIG_EFI=y
CONFIG_EFI_STUB=y
CONFIG_INTEGRITY=y
CONFIG_INTEGRITY_SIGNATURE=y
CONFIG_INTEGRITY_ASYMMETRIC_KEYS=y
CONFIG_SYSTEM_BLACKLIST_KEYRING=y
CONFIG_LOAD_UEFI_KEYS=y
CONFIG_INTEGRITY_PLATFORM_KEYRING=y

# TPM 2.0 (physical TPM on bare metal; vTPM under QEMU).
CONFIG_TCG_TPM=y
CONFIG_TCG_TIS=y
CONFIG_TCG_TIS_CORE=y
CONFIG_TCG_CRB=y
CONFIG_HW_RANDOM_TPM=y

# dm-crypt / LUKS for the encrypted state partition.
CONFIG_BLK_DEV_DM=y
CONFIG_DM_CRYPT=y
CONFIG_CRYPTO_AES=y
CONFIG_CRYPTO_XTS=y
CONFIG_CRYPTO_SHA256=y
# File locking (flock/fcntl). The tiny base disables CONFIG_FILE_LOCKING, so
# flock() returns ENOSYS; cryptsetup takes an flock on its per-device lock file
# (/run/cryptsetup/L_*) and luksFormat then fails with "Cannot format device"
# (cryptsetup --debug: "Flock on fd 8 failed with errno 38"). Required for any
# LUKS operation.
CONFIG_FILE_LOCKING=y

# SquashFS read-only rootfs + overlay (extensions, Phase 3) + tmpfs.
CONFIG_SQUASHFS=y
CONFIG_SQUASHFS_XZ=y
CONFIG_OVERLAY_FS=y
# Loop device: the switch-root shim loop-mounts the RAM-resident SquashFS.
CONFIG_BLK_DEV_LOOP=y
CONFIG_TMPFS=y
CONFIG_DEVTMPFS=y
CONFIG_DEVTMPFS_MOUNT=y

# Networking: rtnetlink + IPv4 (static config via internal/init/netlink).
CONFIG_NET=y
CONFIG_INET=y
CONFIG_UNIX=y

# Boot-time IP autoconfiguration (kernel ip=dhcp), used by maintenance mode to
# obtain an address before any machine config exists. Harmless for installed
# boots, which reconfigure the interface statically from the machine config.
CONFIG_IP_PNP=y
CONFIG_IP_PNP_DHCP=y

# QEMU guest drivers + boot essentials for the Phase 1 ceremony (see #85/#34).
# The tiny base omits these; without them the guest can't exec init, log to the
# serial console, or see the virtio NIC/disk the integration harness wires up.
# Boot fundamentals the tiny base strips (a normal defconfig has these on):
#   PRINTK          — without it the kernel emits NO output at all (silent panic).
#   BLK_DEV_INITRD  — load the shim initramfs; the whole switch-root boot needs it.
#   RD_GZIP         — the shim initrd is cpio.gz; decompress it.
#   PROC_FS         — /proc, required by init and userspace tooling.
CONFIG_PRINTK=y
CONFIG_BLK_DEV_INITRD=y
CONFIG_RD_GZIP=y
CONFIG_PROC_FS=y
# Exec ELF userspace (the Go /init and cryptosctl).
CONFIG_BINFMT_ELF=y
# Go runtime syscall subsystems. The entire userspace (init, cryptosctl) is Go;
# the tiny base strips these and the Go runtime segfaults at startup without
# FUTEX (see runtime/os_linux.go). EPOLL backs the netpoller (the mTLS gRPC
# listener); the fd/barrier syscalls are used across the runtime.
CONFIG_FUTEX=y
CONFIG_EPOLL=y
CONFIG_EVENTFD=y
CONFIG_SIGNALFD=y
CONFIG_TIMERFD=y
CONFIG_MEMBARRIER=y
CONFIG_RSEQ=y
CONFIG_ADVISE_SYSCALLS=y
# Serial console for the qemu-dev cmdline (`console=ttyS0`).
CONFIG_TTY=y
CONFIG_SERIAL_8250=y
CONFIG_SERIAL_8250_CONSOLE=y
# virtio transport + the NIC and block device the harness attaches.
# VIRTIO_MENU gates the whole virtio drivers menu; the tiny base leaves it off,
# which silently drops every virtio driver below.
CONFIG_VIRTIO_MENU=y
CONFIG_VIRTIO=y
CONFIG_VIRTIO_PCI=y
CONFIG_VIRTIO_NET=y
CONFIG_VIRTIO_BLK=y
CONFIG_NETDEVICES=y
# GPT partition parsing (locate the cryptos-state partition) + ext4 (state fs).
CONFIG_PARTITION_ADVANCED=y
CONFIG_EFI_PARTITION=y
CONFIG_EXT4_FS=y

# Hardening defaults.
CONFIG_STRICT_KERNEL_RWX=y
CONFIG_RANDOMIZE_BASE=y
CONFIG_INIT_STACK_ALL_ZERO=y
CONFIG_INIT_ON_ALLOC_DEFAULT_ON=y
CONFIG_INIT_ON_FREE_DEFAULT_ON=y
CONFIG_BUG_ON_DATA_CORRUPTION=y
CONFIG_FORTIFY_SOURCE=y
