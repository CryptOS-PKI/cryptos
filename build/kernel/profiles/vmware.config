# CryptOS platform profile: VMware virtual hardware.
#
# Additive fragment merged onto build/kernel/cryptos.config by build.sh when
# PLATFORM=vmware. Enables the disk + NIC drivers a VMware VM presents so the
# image boots there. Keep MODULES=n: every driver is built in.

# Disk controllers (VMware: NVMe or SATA/AHCI; PVSCSI paravirtual).
CONFIG_BLK_DEV_NVME=y
CONFIG_ATA=y
CONFIG_SATA_AHCI=y
CONFIG_SCSI=y
CONFIG_BLK_DEV_SD=y
CONFIG_VMWARE_PVSCSI=y

# CD-ROM / ISO boot support. VMware attaches the CD-ROM to its emulated PIIX4
# IDE controller by default, so ATA_PIIX is needed for the drive to enumerate;
# the ATAPI CD is then routed via libata→SCSI (BLK_DEV_SR, which selects CDROM).
# ISO9660_FS enables mounting the ISO9660 volume so LocateBootUKI can read
# cryptos.uki from the CD root when there is no GPT EFI partition (Refs #115).
CONFIG_ATA_PIIX=y
CONFIG_BLK_DEV_SR=y
CONFIG_ISO9660_FS=y

# NICs (VMware: e1000e or vmxnet3 paravirtual).
# ETHERNET + NET_VENDOR_INTEL gate the e1000e driver in the Kconfig hierarchy.
CONFIG_ETHERNET=y
CONFIG_NET_VENDOR_INTEL=y
CONFIG_E1000E=y
CONFIG_VMXNET3=y
