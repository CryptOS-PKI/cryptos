# Pinned toolchain + artifact versions for the CryptOS image build.
#
# Sourced by the build/*.sh scripts. Reproducibility depends on these
# being exact pins; bump deliberately and re-verify the checksums below.
#
# DRAFT: versions are reasonable starting pins; verify each release +
# checksum before the first real build on the Linux host.

# Go toolchain (CGO_ENABLED=0 static binaries).
GO_VERSION=1.24.4

# Linux kernel — current LTS line. Built from source, CONFIG_MODULES=n.
# Sourced from the canonical stable git tag (v${KERNEL_VERSION}), not a
# cdn.kernel.org tarball: superseded point releases are pruned from the CDN, so
# a pinned tarball URL 404s once a newer point release lands. The git tag is
# permanent. Integrity is anchored to the tag (commit-level pinning is a future
# hardening); there is no tarball checksum to maintain.
KERNEL_VERSION=6.12.94

# systemd provides ukify + the systemd-stub EFI stub used for the UKI.
SYSTEMD_VERSION=256

# Static cryptsetup shipped in the rootfs (LUKS2 open/format). Built from
# source against musl (Alpine) so it runs in the no-libc rootfs.
CRYPTSETUP_VERSION=2.7.5
# SHA-256 of cryptsetup-${CRYPTSETUP_VERSION}.tar.xz from kernel.org, matching
# https://cdn.kernel.org/pub/linux/utils/cryptsetup/v2.7/sha256sums.asc.
CRYPTSETUP_SHA256=d2be4395b8f503b0ebf4b2d81db90c35a97050a358ee21fe62a0dfb66e5d5522
# Pinned Alpine builder image (musl toolchain + static dev libs).
ALPINE_BUILDER=alpine:3.21

# e2fsprogs: a static mke2fs is baked into the rootfs as /sbin/mkfs.ext4 (init
# formats the unlocked state volume with it on first boot). Sourced from the git
# tag and built glibc-static in Debian — the in-tree libblkid does not
# static-link on musl (llseek), so the Alpine base can't produce it.
E2FSPROGS_VERSION=1.47.1
DEBIAN_BUILDER=debian:12-slim

# gptfdisk: a static sgdisk is baked into the rootfs as /sbin/sgdisk (installer
# uses it to lay out the GPT). Built glibc-static from the Debian package source
# (popt static archive not reliably present on Alpine). This is the version
# Debian 12 ships; bump together with DEBIAN_BUILDER.
GPTFDISK_VERSION=1.0.9

# dosfstools: a static mkfs.vfat is baked into the rootfs as /sbin/mkfs.vfat
# (installer formats the EFI System Partition). Sourced from the git tag and
# built glibc-static in Debian.
DOSFSTOOLS_VERSION=4.2

# squashfs-tools (mksquashfs).
SQUASHFS_TOOLS_VERSION=4.6.1

# Integration-test toolchain (consumed by the QEMU harness).
QEMU_VERSION=9.0.2
SWTPM_VERSION=0.10.0
OVMF_VERSION=stable202405
ZLINT_VERSION=3.6.5

# Target architectures for the UKI.
ARCHES="amd64 arm64"

# ISO factory toolchain (build/iso/build.sh): xorriso, mtools, dosfstools.
# Installed from the builder distro; no upstream tarball pin (host packages).
