# Pinned toolchain + artifact versions for the CryptOS image build.
#
# Sourced by the build/*.sh scripts. Reproducibility depends on these
# being exact pins; bump deliberately and re-verify the checksums below.
#
# DRAFT: versions are reasonable starting pins; verify each release +
# checksum before the first real build on the Linux host.

# Go toolchain (CGO_ENABLED=0 static binaries).
GO_VERSION=1.24.4

# Linux kernel — current LTS line. Built from source, CONFIG_MODULES=n.
KERNEL_VERSION=6.12.30
# SHA-256 of linux-${KERNEL_VERSION}.tar.xz from kernel.org, matching the
# value published in https://cdn.kernel.org/pub/linux/kernel/v6.x/sha256sums.asc.
KERNEL_SHA256=df046a48971e40ce0b2e003e7e55b6b1e7da2912120eb216d5d6c8450c9cf82e

# systemd provides ukify + the systemd-stub EFI stub used for the UKI.
SYSTEMD_VERSION=256

# Static cryptsetup shipped in the rootfs (LUKS2 open/format).
CRYPTSETUP_VERSION=2.7.5

# squashfs-tools (mksquashfs).
SQUASHFS_TOOLS_VERSION=4.6.1

# Integration-test toolchain (consumed by the QEMU harness).
QEMU_VERSION=9.0.2
SWTPM_VERSION=0.10.0
OVMF_VERSION=stable202405
ZLINT_VERSION=3.6.5

# Target architectures for the UKI.
ARCHES="amd64 arm64"
